<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".PaymentActivity">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#6A6666">

        <!-- Below is a message textview   -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Please Complete your payment with MPesa"
            android:textSize="32sp"
            android:textAlignment="center"
            android:layout_marginTop="10dp"
            android:textStyle="bold"
            android:textColor="#33BA39"/>

        <!--  Below is a cardview that holds all our content  -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            app:cardElevation="12dp"
            app:cardCornerRadius="22dp">

            <!--   Below is a linear layout     -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#4FB8C5">

                <TextView
                    android:id="@+id/txtProductName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Product Name"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="#000"/>

                <ImageView
                    android:id="@+id/imgProduct"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop"
                    android:layout_marginTop="10dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"/>

                <TextView
                    android:id="@+id/txtProductCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ksh 1000"
                    android:textSize="30sp"
                    android:layout_marginTop="5dp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="#000"/>

                <TextView
                    android:id="@+id/txtProductDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This is the product description for the payment page"
                    android:textSize="20sp"
                    android:textColor="#000"
                    android:textStyle="italic|bold"/>

                <EditText
                    android:id="@+id/phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter your Phone Number"
                    android:textColorHint="#524D4D"
                    android:textColor="@color/white"
                    android:layout_marginTop="10dp"/>

                <Button
                    android:id="@+id/pay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pay Now"
                    android:layout_marginTop="25dp"
                    android:textSize="20sp"
                    android:layout_marginLeft="70dp"
                    android:layout_marginRight="70dp"
                    android:backgroundTint="#1E5920"
                    android:textColor="@color/white"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>